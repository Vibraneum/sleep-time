<?xml version="1.0" encoding="utf-8"?>
<!--
  Slim countdown banner shown during a grant (allow-list non-empty). Sits at the
  top of the screen over the allowed app, reminding the user how long they have
  before the lock re-arms. Compact, non-blocking, tappable to open Sleep Time.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#E60D0D1A"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/banner_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Borrowed time"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/banner_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFF9500"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />
</LinearLayout>
