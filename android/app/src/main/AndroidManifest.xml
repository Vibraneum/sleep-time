<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ requires a typed foreground service permission. The
         bedtime guardian uses the "specialUse" type; see the <service>
         declaration below for the mandatory subtype justification. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Left in place for the M5 overlay/AccessibilityService work. No
         usage-access or overlay logic ships in M4. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Keep the device awake long enough to post the schedule notifications
         when an alarm fires while the device is idle. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Android 13+ runtime notification permission, used for the persistent
         guardian notification + wind-down / lockdown / unlock reminders. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for the schedule to fire at exactly the configured wind-down /
         lockdown / unlock times on Android 12+. We guard every exact-alarm call
         with canScheduleExactAlarms() and degrade gracefully (inexact window)
         when the user has not granted it, so we deliberately do NOT request the
         auto-granted USE_EXACT_ALARM (a Play-restricted permission). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Lets the user exempt the guardian from Doze battery optimisation so the
         bedtime alarms survive overnight. Requested at runtime via the system
         dialog; never auto-applied. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- PRIMARY foreground-app detector. UsageStatsManager is the source of
         truth for which app is in front while locked; the optional
         AccessibilityService below only feeds it faster. This is a protected
         permission granted by the user from the system Usage-Access screen
         (never auto-granted), so we annotate it for lint. We deliberately do
         NOT add QUERY_ALL_PACKAGES — the app catalog uses
         getInstalledApplications(0), which needs no package-visibility grant. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="sleep time"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- Background bedtime guardian. specialUse FGS: it enforces a
             user-configured lock schedule while the app is backgrounded. The
             nested PROPERTY_SPECIAL_USE_FGS_SUBTYPE string is mandatory on
             Android 14+ and is what Play review reads. -->
        <service
            android:name=".SleepGuardianService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Enforces a user-configured bedtime lock schedule while the app is backgrounded." />
        </service>

        <!-- Fires the WIND_DOWN / LOCK / UNLOCK alarms. In-process only. -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false" />

        <!-- Re-arms alarms after a reboot. Android 15 forbids starting a
             specialUse FGS directly from BOOT_COMPLETED, so this receiver only
             enqueues an expedited WorkManager job (GuardianBootWorker). -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- OPTIONAL latency enhancement only. The app is fully functional with
             this service disabled (UsageStats is the primary detector). It is an
             observe-only Digital Wellbeing helper: typeWindowStateChanged only,
             no input injection, NOT flagged isAccessibilityTool. Android 17
             Advanced Protection can silently revoke it; the guardian must not
             depend on it. A prominent disclosure dialog is shown in-app BEFORE
             the user is ever sent to the Accessibility settings. -->
        <service
            android:name=".SleepAccessibilityService"
            android:exported="false"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Make launchable third-party apps visible to getInstalledApplications
             under targetSdk 30+ package visibility, so the negotiable-app /
             allow-list picker is populated. Play-compliant: this is the
             recommended <intent> filter and deliberately NOT QUERY_ALL_PACKAGES. -->
        <intent>
            <action android:name="android.intent.action.MAIN"/>
            <category android:name="android.intent.category.LAUNCHER"/>
        </intent>
    </queries>
</manifest>
